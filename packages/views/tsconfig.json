{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@openzoo/core": ["../core/src/index.ts"],
      "@openzoo/core/*": ["../core/src/*"],
      "@openzoo/ui": ["../ui/src/index.ts"],
      "@openzoo/ui/*": ["../ui/src/*"]
    }
  },
  "include": ["src"]
}
